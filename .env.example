# DoomScroll Detox - .env.example
#
# Copy this file to .env and fill in real values. NEVER commit the real
# .env file -- it should already be covered by .gitignore (see below).
#
#   cp .env.example .env
#
# Backend values (GEMINI_API_KEY, SUPABASE_URL, SUPABASE_ANON_KEY) are
# consumed by backend/ai_service.py at runtime via os.environ. When
# deploying to Vercel, these are NOT read from this file -- set them
# separately in your Vercel project dashboard under
# Settings -> Environment Variables. This file is for local development
# only (e.g. `vercel dev`).

# --------------------------------------------------------------------------
# Backend (backend/)
# --------------------------------------------------------------------------

# Google AI Studio API key (https://aistudio.google.com/) -- powers the
# roast generator and the unlock question/answer grading in
# backend/ai_service.py.
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project settings (from Project Settings -> API in your
# Supabase dashboard). Used for persisting user_profiles / fail_logs
# per the schema in Step 1 of the README.
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --------------------------------------------------------------------------
# Client (client/)
# --------------------------------------------------------------------------

# Base URL of your deployed backend (no trailing slash). Defaults to
# http://localhost:3000 in client/config.py if not set -- override this
# once you've deployed to Vercel.
DOOMSCROLL_BACKEND_URL=https://your-project.vercel.app
